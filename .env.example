# Get a free key at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# Bounding box "west,south,east,north" for FIRMS area queries.
# Default covers mainland Spain + Balearics. FIRMS' country-code endpoint
# returns "Invalid API call" as of 2026-07, so we use the area/bbox endpoint instead.
FIRMS_BBOX=-9.5,35.9,4.4,43.9

# Queried satellite sources are fixed in app/config.py (firms_sources) - VIIRS
# S-NPP/NOAA-20/NOAA-21 + MODIS, matching what NASA's own FIRMS map overlays.
# Querying only one satellite misses real fires: on 2026-07-13, VIIRS_SNPP_NRT
# alone returned 0 rows for Spain while NOAA-20 had 111 and NOAA-21 had 68.

# How often (minutes) the backend re-polls FIRMS/EFFIS.
# 180 (3h) matches the real revisit cadence of combined VIIRS/MODIS NRT passes.
FETCH_INTERVAL_MINUTES=180
